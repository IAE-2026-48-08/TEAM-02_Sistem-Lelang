                    "Winners"
                ],
                "summary": "Proses checkout pemenang (dilindungi JWT SSO)",
                "description": "POST /api/v1/winners\nCheckout a won auction item.",
                "operationId": "9dc6492e64e285cba7799b8235cac0d4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
