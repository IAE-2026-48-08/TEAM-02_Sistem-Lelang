                                    "user_id",
                                    "winning_bid"
                                ],
                                "properties": {
                                    "auction_item_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "winning_bid": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 5000000
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Checkout berhasil",
                        "content": {
